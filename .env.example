# Copy to `.env` and fill in. `.env` is gitignored.
# Used by Hugging Face Hub CLI / transformers / huggingface_hub for downloads (Gemma, ColEmbed, BART, etc.).

# Optional — mirror `git config user.name` / `user.email` (Git does not load .env; use for your own scripts or manual copy).
# GIT_USER_NAME=your_github_username
# GIT_USER_EMAIL=your.id+username@users.noreply.github.com

# Required for gated or private models; recommended for higher Hub rate limits.
HF_TOKEN=YOUR_HF_TOKEN_HERE

# Optional alias — huggingface_hub reads either HF_TOKEN or HUGGING_FACE_HUB_TOKEN.
HUGGING_FACE_HUB_TOKEN=YOUR_HF_TOKEN_HERE

# Optional (CLI / organization display); Hub auth is token-based.
HF_USERNAME=YOUR_HF_USERNAME

# Optional — Hugging Face Dataset upload (data/upload_webqa_to_hf.py)
# Default repo id is {HF_USERNAME}/webqa ; override if needed:
# HF_DATASET_REPO=yourname/webqa
# HF_DATASET_NAME=webqa
# HF_PRIVATE_DATASET=0
